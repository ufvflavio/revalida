        <div class="form-group">
            <label for="cpf">CPF:</label>
            <input type="text" id="cpf" placeholder="000.000.000-00" required>
        </div>
        
        <div class="form-group">
            <label for="funcao">Função Exercida:</label>
            <select id="funcao" required>
                <option value="" disabled selected>Selecione a função...</option>
                <option value="ASSISTENTE DO SUPERVISOR DOS PAC. SIMULADOS">ASSISTENTE DO SUPERVISOR DOS PACIENTES SIMULADOS</option>
                <option value="CHEFE DE ESTAÇÃO">CHEFE DE ESTAÇÃO</option>
                <option value="CHEFE DE MÓDULO">CHEFE DE MÓDULO</option>
                <option value="OPERADOR DE CÂMERA">OPERADOR DE CÂMERA</option>
                <option value="PACIENTES SIMULADOS">PACIENTES SIMULADOS</option>
                <option value="SUPERVISOR DOS OPERADORES DE CÂMERA">SUPERVISOR DOS OPERADORES DE CÂMERA</option>
            </select>
        </div>
        
        <div class="form-group">
            <label for="data_atuacao">Data de Atuação:</label>
            <select id="data_atuacao" required>
                <option value="" disabled selected>Selecione a data...</option>
                <option value="16 de maio de 2026">16 de maio de 2026</option>
                <option value="17 de maio de 2026">17 de maio de 2026</option>
                <option value="16 e 17 de maio de 2026">16 e 17 de maio de 2026</option>
            </select>
        </div>

        <button type="submit">Gerar e Baixar PDF</button>
        <div id="loadingMsg" class="loading">Gerando PDF...</div>
    </form>
</div>

<img id="documentoBase" src="data:image/jpeg;base64," style="display:none;" crossorigin="anonymous">

<script>
    async function gerarPDF(event) {
        event.preventDefault();
        const { jsPDF } = window.jspdf;
        const loadingMsg = document.getElementById('loadingMsg');
        loadingMsg.style.display = 'block';

        // Coleta de dados
        const nome = document.getElementById('nome').value.toUpperCase();
        const cpf = document.getElementById('cpf').value;
        const funcao = document.getElementById('funcao').value.toUpperCase();
        const dataAtuacao = document.getElementById('data_atuacao').value;

        // Data atual automática
        const hoje = new Date();
        const dia = String(hoje.getDate()).padStart(2, '0');
        const meses = ["janeiro", "fevereiro", "março", "abril", "maio", "junho", "julho", "agosto", "setembro", "outubro", "novembro", "dezembro"];
        const mesExtenso = meses[hoje.getMonth()];

        const hospital = "DIVISAO DE SAUDE DA UFV";
        const cidade = "VIÇOSA - MG";

        // ==========================================
        // CONFIGURAÇÃO DE POSIÇÕES (EM MILÍMETROS)
        // Se o texto ficar fora da linha, ajuste os valores abaixo.
        // X = Direita/Esquerda | Y = Cima/Baixo
        // ==========================================
        const posicoes = {
            nome1:     { x: 32,  y: 117.5 },
            cpf:       { x: 32,  y: 123.5 },
            funcao:    { x: 55,  y: 129.5 },
            dias:      { x: 32,  y: 135.5 },
            hospital:  { x: 32,  y: 142.5 },
            cidade:    { x: 32,  y: 149.5 },
            nome2:     { x: 32,  y: 168.5 },
            diaEmissao:{ x: 62,  y: 212.5 },
            mesEmissao:{ x: 79,  y: 212.5 }
        };
        // ==========================================

        const img = document.getElementById('documentoBase');
        
        if(img.src.includes("LINK_DA_IMAGEM_AQUI")) {
            alert("Por favor, coloque o link ou caminho da imagem na tag <img> no código HTML.");
            loadingMsg.style.display = 'none';
            return;
        }

        const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

        try {
            pdf.addImage(img, 'JPEG', 0, 0, 210, 297);
            pdf.setFont("Helvetica", "bold");
            pdf.setFontSize(10.5);
            pdf.setTextColor(0, 0, 0);

            // Inserção dos textos usando a configuração acima
            pdf.text(nome, posicoes.nome1.x, posicoes.nome1.y);
            pdf.text(cpf, posicoes.cpf.x, posicoes.cpf.y);
            pdf.text(funcao, posicoes.funcao.x, posicoes.funcao.y);
            pdf.text(dataAtuacao, posicoes.dias.x, posicoes.dias.y);
            pdf.text(hospital, posicoes.hospital.x, posicoes.hospital.y);
            pdf.text(cidade, posicoes.cidade.x, posicoes.cidade.y);
            
            // Inserindo o nome na segunda posição (atividades exercidas por...)
            pdf.text(nome, posicoes.nome2.x, posicoes.nome2.y);

            // Data de assinatura (Rio de Janeiro, ___ de ____________ de 2026)
            pdf.text(dia, posicoes.diaEmissao.x, posicoes.diaEmissao.y);
            pdf.text(mesExtenso, posicoes.mesEmissao.x, posicoes.mesEmissao.y);

            pdf.save(`Declaracao_Revalida_${nome.replace(/\s+/g, '_')}.pdf`);
        } catch (error) {
            alert("Erro ao renderizar o PDF. Verifique se o caminho da imagem está correto e acessível.");
            console.error(error);
        } finally {
            loadingMsg.style.display = 'none';
        }
    }
</script>

</body>
</html>
