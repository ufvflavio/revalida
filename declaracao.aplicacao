                <option value="SOFIA DOS SANTOS DUARTE">SOFIA DOS SANTOS DUARTE</option>
                <option value="TAINARA CERQUEIRA CARDOSO">TAINARA CERQUEIRA CARDOSO</option>
                <option value="TALITA PRADO SIMÃO MIRANDA">TALITA PRADO SIMÃO MIRANDA</option>
                <option value="TAMIRES AMANDA DUARTE">TAMIRES AMANDA DUARTE</option>
                <option value="TATIANA MEDEIROS DE SOUZA">TATIANA MEDEIROS DE SOUZA</option>
                <option value="THAINÁ CRISTINA GONÇALVES DE AGUIAR">THAINÁ CRISTINA GONÇALVES DE AGUIAR</option>
                <option value="THAÍS ROCHA DOS SANTOS OLIVEIRA">THAÍS ROCHA DOS SANTOS OLIVEIRA</option>
